PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Minified JSON from Firebase Console → Project settings → Service accounts → Generate new private key
# Single line; escape newlines in private_key as \n
FIREBASE_SERVICE_ACCOUNT=

# Web API key (Firebase Console → Project settings → Your apps). Rotate if leaked.
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_DATABASE_URL=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=
